---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base
  title="Writing"
  description="Architecture decisions, production lessons, patterns that hold."
>
  <div class="mx-auto max-w-3xl px-6 py-20">
    <h1 class="text-4xl font-bold text-slate-100 mb-4">Writing</h1>
    <p class="text-slate-400 text-lg mb-12">
      Architecture decisions, production lessons, patterns that hold.
    </p>

    <div>
      {articles.map(article => <ArticleCard article={article} />)}
    </div>
  </div>
</Base>
